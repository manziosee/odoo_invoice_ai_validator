<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ai_payment_validator_settings" model="ir.ui.view">
        <field name="name">res.config.settings.ai.payment.validator</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="AI Payment Validator" name="odoo_invoice_ai_validator">
                    <block title="Groq AI">
                        <setting string="Groq API Key"
                                 help="Get a free key at https://console.groq.com">
                            <field name="groq_api_key" password="True"/>
                        </setting>
                        <setting string="Groq Model">
                            <field name="groq_model"/>
                        </setting>
                        <setting string="Max Retries on Groq Error">
                            <field name="groq_max_retries"/>
                        </setting>
                    </block>
                    <block title="Invoice Matching">
                        <setting string="Amount Match Tolerance (%)"
                                 help="Max % difference between extracted and invoice amount. Default 2%.">
                            <field name="match_amount_tolerance"/>
                        </setting>
                    </block>
                    <block title="Integrations">
                        <setting string="Telegram Bot Token"
                                 help="From @BotFather — enables WhatsApp/Telegram proof uploads.">
                            <field name="telegram_token" password="True"/>
                        </setting>
                        <setting string="Twilio Account SID"
                                 help="For WhatsApp integration via Twilio.">
                            <field name="twilio_sid"/>
                        </setting>
                        <setting string="Twilio Auth Token">
                            <field name="twilio_token" password="True"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
