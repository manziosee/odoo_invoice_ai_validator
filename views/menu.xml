<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Define all actions first, then menus that reference them -->

    <record id="action_payment_proof" model="ir.actions.act_window">
        <field name="name">Payment Proofs</field>
        <field name="res_model">payment.proof</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_partner_scoring_rule" model="ir.actions.act_window">
        <field name="name">Partner Matching Rules</field>
        <field name="res_model">payment.partner.rule</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_payment_proof_audit" model="ir.actions.act_window">
        <field name="name">Audit Log</field>
        <field name="res_model">payment.proof.audit</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'create': False}</field>
    </record>

    <!-- Root menu under Accounting -->
    <menuitem id="menu_payment_proof_root"
              name="AI Payment Validator"
              parent="account.menu_finance"
              sequence="99"/>

    <menuitem id="menu_payment_proof_list"
              name="Payment Proofs"
              parent="menu_payment_proof_root"
              action="action_payment_proof"
              sequence="1"/>

    <menuitem id="menu_partner_scoring_rules"
              name="Partner Matching Rules"
              parent="menu_payment_proof_root"
              action="action_partner_scoring_rule"
              sequence="2"/>

    <menuitem id="menu_payment_proof_audit"
              name="Audit Log"
              parent="menu_payment_proof_root"
              action="action_payment_proof_audit"
              sequence="3"
              groups="account.group_account_manager"/>
</odoo>
