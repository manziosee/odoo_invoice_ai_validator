<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_scoring_rule_tree" model="ir.ui.view">
        <field name="name">payment.partner.rule.tree</field>
        <field name="model">payment.partner.rule</field>
        <field name="arch" type="xml">
            <tree string="Partner Matching Rules">
                <field name="partner_id"/>
                <field name="reference_weight"/>
                <field name="amount_weight"/>
                <field name="amount_tolerance"/>
                <field name="name_weight"/>
                <field name="correction_count"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_partner_scoring_rule_form" model="ir.ui.view">
        <field name="name">payment.partner.rule.form</field>
        <field name="model">payment.partner.rule</field>
        <field name="arch" type="xml">
            <form string="Partner Matching Rule">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="partner_id" placeholder="Select client…"/></h1>
                    </div>
                    <group string="Score Weights">
                        <group>
                            <field name="reference_weight"/>
                            <field name="amount_weight"/>
                        </group>
                        <group>
                            <field name="name_weight"/>
                            <field name="amount_tolerance"/>
                        </group>
                    </group>
                    <group string="Reference Pattern">
                        <group col="1">
                            <field name="reference_pattern"
                                   placeholder='e.g. UNICEF|PROG-\d+ (regex)'/>
                        </group>
                    </group>
                    <group string="Stats">
                        <field name="correction_count" readonly="1"/>
                        <field name="active"/>
                    </group>
                    <group string="Notes">
                        <group col="1">
                            <field name="notes" nolabel="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
