<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_payment_proof_audit_tree" model="ir.ui.view">
        <field name="name">payment.proof.audit.tree</field>
        <field name="model">payment.proof.audit</field>
        <field name="arch" type="xml">
            <tree string="Audit Log" create="false" edit="false" delete="false"
                  decoration-success="action == 'validated'"
                  decoration-danger="action == 'error'"
                  decoration-warning="action == 'no_match'">
                <field name="create_date" string="Date"/>
                <field name="proof_id"/>
                <field name="action" widget="badge"
                       decoration-success="action == 'validated'"
                       decoration-danger="action == 'error'"
                       decoration-warning="action in ('no_match','corrected')"/>
                <field name="actor_id"/>
                <field name="result"/>
                <field name="invoices_considered"/>
            </tree>
        </field>
    </record>

    <record id="view_payment_proof_audit_form" model="ir.ui.view">
        <field name="name">payment.proof.audit.form</field>
        <field name="model">payment.proof.audit</field>
        <field name="arch" type="xml">
            <form string="Audit Entry" create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="create_date" string="Date" readonly="1"/>
                            <field name="proof_id" readonly="1"/>
                            <field name="action" readonly="1"/>
                            <field name="actor_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="result" readonly="1"/>
                            <field name="invoices_considered" readonly="1"/>
                        </group>
                    </group>
                    <group string="Score Breakdown">
                        <group col="1">
                            <field name="score_breakdown" readonly="1" nolabel="1"/>
                        </group>
                    </group>
                    <group string="Extracted Data (JSON)" groups="base.group_no_one">
                        <group col="1">
                            <field name="extracted_data" readonly="1" nolabel="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
