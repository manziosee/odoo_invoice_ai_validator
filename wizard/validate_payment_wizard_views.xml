<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_validate_payment_wizard_form" model="ir.ui.view">
        <field name="name">validate.payment.wizard.form</field>
        <field name="model">validate.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirm Payment Validation">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Review and adjust below, then click Register Payment.
                        You can pay multiple invoices at once if the proof covers them all.
                    </div>

                    <group string="AI Match Summary">
                        <group>
                            <field name="match_confidence" readonly="1" widget="percentage" string="AI Confidence"/>
                            <field name="matched_invoice_count" readonly="1" string="Invoices Found"/>
                        </group>
                        <group col="1">
                            <field name="match_notes" readonly="1" nolabel="1"/>
                        </group>
                    </group>

                    <group string="Invoices to Pay">
                        <field name="invoice_ids" nolabel="1">
                            <tree>
                                <field name="name"/>
                                <field name="partner_id"/>
                                <field name="invoice_date"/>
                                <field name="amount_residual"/>
                                <field name="currency_id"/>
                                <field name="payment_state" widget="badge"/>
                            </tree>
                        </field>
                    </group>

                    <group string="Payment Details">
                        <group>
                            <field name="payment_date" required="1"/>
                            <field name="journal_id" required="1"/>
                        </group>
                        <group>
                            <field name="payment_reference"/>
                            <field name="currency_id"/>
                        </group>
                    </group>

                    <group string="Partial Payment" invisible="matched_invoice_count != 1">
                        <group>
                            <field name="use_extracted_amount"/>
                            <field name="extracted_amount" readonly="1"
                                   invisible="not use_extracted_amount"
                                   string="Amount from proof"/>
                        </group>
                    </group>

                    <field name="proof_id" invisible="1"/>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Register Payment"
                            type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
